{
  "name": "zimeiti-creator",
  "version": "2.0.0",
  "description": "自媒体创作助手 — AI驱动的对话式内容创作工具",
  "main": "main.js",
  "author": "zengyuan26",
  "license": "MIT",
  "scripts": {
    "start": "node dev-server.js",
    "start:electron": "npx electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build": "echo 'no build needed — static HTML'"
  },
  "devDependencies": {},
  "build": {
    "appId": "com.zimeiti.creator",
    "productName": "自媒体创作助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "app.js",
      "styles.css",
      "supabase.js",
      "index.html"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "自媒体创作助手",
      "installerLanguages": [
        "zh-CN"
      ],
      "language": "2052",
      "unicode": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {}
}
