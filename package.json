{
  "name": "zimeiti-creator",
  "version": "2.0.0",
  "description": "自媒体创作助手 — AI驱动的对话式内容创作工具",
  "main": "main.js",
  "author": "zengyuan26",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder --win --x64 --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.zimeiti.creator",
    "productName": "自媒体创作助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "自媒体创作助手",
      "installerLanguages": ["zh-CN"],
      "language": "2052",
      "unicode": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  }
}
